{
  "tls": {
    "min_version": "1.2",
    "cipher_suites": [
      "TLS_ECDHE_RSA_WITH_AES_256_GCM_SHA384",
      "TLS_ECDHE_RSA_WITH_AES_128_GCM_SHA256",
      "TLS_RSA_WITH_AES_256_GCM_SHA384"
    ]
  },
  "cors": {
    "allowed_origins": [
      "https://memristor-nn.com",
      "https://*.memristor-nn.com"
    ],
    "allowed_methods": [
      "GET",
      "POST",
      "PUT",
      "DELETE",
      "OPTIONS"
    ],
    "allowed_headers": [
      "Content-Type",
      "Authorization",
      "X-API-Key"
    ],
    "expose_headers": [
      "X-Request-ID"
    ],
    "max_age": 86400
  },
  "rate_limiting": {
    "requests_per_minute": 1000,
    "burst_size": 100,
    "per_ip_limit": 100
  },
  "authentication": {
    "jwt": {
      "algorithm": "RS256",
      "expiration": 3600,
      "refresh_expiration": 86400
    },
    "api_keys": {
      "required": true,
      "header_name": "X-API-Key"
    }
  },
  "data_protection": {
    "encryption_at_rest": true,
    "encryption_in_transit": true,
    "key_rotation_days": 90,
    "data_retention_days": 365
  },
  "compliance": {
    "gdpr": {
      "enabled": true,
      "consent_required": true,
      "data_portability": true,
      "right_to_deletion": true
    },
    "ccpa": {
      "enabled": true,
      "opt_out_available": true
    },
    "pdpa": {
      "enabled": true,
      "consent_required": true
    }
  }
}