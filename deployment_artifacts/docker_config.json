{
  "image": "memristor-nn-simulator:1.0.0",
  "base_image": "python:3.9-slim",
  "ports": [
    8080,
    8443
  ],
  "environment": {
    "ENV": "production",
    "APP_VERSION": "1.0.0",
    "PYTHONPATH": "/app",
    "WORKERS": 4
  },
  "healthcheck": {
    "test": [
      "CMD",
      "curl",
      "-f",
      "http://localhost:8080/health"
    ],
    "interval": "30s",
    "timeout": "10s",
    "retries": 3
  },
  "security": {
    "user": "nobody",
    "read_only": true,
    "no_new_privileges": true
  }
}